{
  "version": 2,
  "buildCommand": "cd frontend && npm run build",
  "outputDirectory": "frontend/dist",
  "functions": {
    "api/index.py": {
      "runtime": "@vercel/python"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.py"
    },
    {
      "source": "/storage/(.*)",
      "destination": "/api/index.py"
    },
    {
      "source": "/((?!api/|storage/).*)",
      "destination": "/index.html"
    }
  ],
  "env": {
    "PYTHONPATH": "backend"
  }
}
